# このファイルを .env にコピーして値を設定してください（.env はgit管理外）
#   $ cp .env.example .env
#
# Discord Webhook URL（通知の送信先）
# 取得方法: Discordチャンネル設定 → 連携サービス → ウェブフック → 新規作成 → URLをコピー
DISCORD_WEBHOOK_URL=

# ── J-Quants（日本株の業種分類の取得。業種スコアに使用） ─────────────
# 無料(Free)プランで可。https://jpx-jquants.com/ で登録。
# リフレッシュトークンを使うのが簡単（マイページで発行）。
JQUANTS_REFRESH_TOKEN=
# リフレッシュトークンの代わりにメール+パスワードでも可（どちらか一方でOK）
JQUANTS_MAILADDRESS=
JQUANTS_PASSWORD=
